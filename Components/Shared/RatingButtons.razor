<div class="rating-grid">
    @if (IncludeAgain)
    {
        <button type="button" class="button rating-again" disabled="@Disabled" @onclick="() => OnRate.InvokeAsync(ReviewRating.Again)">@Localizer["Learn_Again"]</button>
    }
    <button type="button" class="button button-secondary" disabled="@Disabled" @onclick="() => OnRate.InvokeAsync(ReviewRating.Hard)">@Localizer["Learn_Hard"]</button>
    <button type="button" class="button button-primary" disabled="@Disabled" @onclick="() => OnRate.InvokeAsync(ReviewRating.Good)">@Localizer["Learn_Good"]</button>
    <button type="button" class="button button-secondary" disabled="@Disabled" @onclick="() => OnRate.InvokeAsync(ReviewRating.Easy)">@Localizer["Learn_Easy"]</button>
</div>

@code {
    [Parameter, EditorRequired]
    public EventCallback<ReviewRating> OnRate { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool IncludeAgain { get; set; }
}
