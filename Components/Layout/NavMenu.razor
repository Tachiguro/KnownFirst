<div class="nav-shell">
    <div class="nav-header">
        <a class="brand" href="" @onclick="NotifyNavigationAsync">@Localizer["App_Name"]</a>
    </div>

    <div class="nav-scrollable">
        <nav class="nav-list" aria-label="@(Localizer["Navigation_Menu"])">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="NotifyNavigationAsync">
                @Localizer["Navigation_Home"]
            </NavLink>
            <NavLink class="nav-link" href="import-text" @onclick="NotifyNavigationAsync">
                @Localizer["Navigation_ImportText"]
            </NavLink>
            <NavLink class="nav-link" href="review-words" @onclick="NotifyNavigationAsync">
                @Localizer["Navigation_ReviewWords"]
            </NavLink>
            <NavLink class="nav-link" href="prepare-words" @onclick="NotifyNavigationAsync">
                @Localizer["Navigation_PrepareWords"]
            </NavLink>
            <NavLink class="nav-link" href="learn" @onclick="NotifyNavigationAsync">
                @Localizer["Navigation_Learn"]
            </NavLink>
            <NavLink class="nav-link" href="dictionary" @onclick="NotifyNavigationAsync">
                @Localizer["Navigation_Dictionary"]
            </NavLink>
            <NavLink class="nav-link" href="settings" @onclick="NotifyNavigationAsync">
                @Localizer["Navigation_Settings"]
            </NavLink>
            @if (IsDebugBuild)
            {
                <NavLink class="nav-link" href="diagnostics" @onclick="NotifyNavigationAsync">
                    @Localizer["Navigation_Diagnostics"]
                </NavLink>
            }
        </nav>
    </div>

    <div class="developer-attribution">
        <span>@Localizer["Footer_DevelopedBy"]</span>
        <img src="images/Tachis_sighn.jpg"
             alt="@(Localizer["Footer_TachiguroLogoAlt"])"
             class="developer-sign" />
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnNavigate { get; set; }

    private static bool IsDebugBuild
    {
        get
        {
#if DEBUG
            return true;
#else
            return false;
#endif
        }
    }

    private Task NotifyNavigationAsync() => OnNavigate.InvokeAsync();
}
