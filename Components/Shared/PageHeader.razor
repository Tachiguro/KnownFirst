<header class="page-header">
    <h1>@Title</h1>
    <a class="back-to-home"
       href=""
       aria-label="@(Localizer["Navigation_BackToHome"])"
       title="@(Localizer["Navigation_BackToHome"])">
        <span aria-hidden="true">&#8592;</span>
        <span>@Localizer["Navigation_BackToHome"]</span>
    </a>
</header>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;
}
