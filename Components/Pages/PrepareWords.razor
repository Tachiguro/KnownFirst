@page "/prepare-words"
@inject IPreparationService PreparationService
@inject IAppSettingsService AppSettings
@inject INavigationHistoryService NavigationHistory
@inject NavigationManager Navigation
@inject IJSRuntime JavaScript
@inject ILogger<PrepareWords> Logger
@implements IAsyncDisposable

<PageTitle>@Localizer["Navigation_PrepareWords"]</PageTitle>

<KnownFirst.Components.Shared.KeyboardShortcutHandler OnKeyDown="HandleKeyDown" />
<section class="workflow-layout">
    <div class="workflow-scroll-area" tabindex="0">
    <PageHeader Title="@(Localizer["Navigation_PrepareWords"])" />

    @if (_isLoading)
    {
        <p class="loading-message preparation-transition-status" role="status">
            <span class="transition-spinner" aria-hidden="true"></span>
            <span>@Localizer["Prepare_Loading"]</span>
        </p>
    }
    else if (_loadFailed)
    {
        <div class="inline-message inline-message-error" role="alert">
            <span>@Localizer["Prepare_LoadError"]</span>
            <button type="button" class="button button-secondary" @onclick="LoadAsync">@Localizer["Common_Retry"]</button>
        </div>
    }
    else if (_showPrivacyDisclosure)
    {
        <section class="preparation-card privacy-disclosure" role="dialog" aria-labelledby="privacy-title">
            <h2 id="privacy-title">@Localizer["Prepare_OnlineDisclosureTitle"]</h2>
            <p>@Localizer["Prepare_OnlineDisclosure"]</p>
            <div class="button-row">
                <button type="button" class="button button-primary" disabled="@_isBusy" @onclick="ConfirmOnlineLookupAsync">@Localizer["Prepare_StartOnlineLookup"]</button>
                <button type="button" class="button button-secondary" disabled="@_isBusy" @onclick="StartManualAsync">@Localizer["Prepare_Manual"]</button>
                <button type="button" class="button button-secondary" disabled="@_isBusy" @onclick="CancelDisclosure">@Localizer["Common_Cancel"]</button>
            </div>
        </section>
    }
    else if (_item is null && !_batchCompleted)
    {
        <section class="preparation-card">
            @if (_overview.UnpreparedCount == 0)
            {
                <h2>@Localizer["Prepare_NoWordsTitle"]</h2>
                <p>@Localizer["Prepare_NoWords"]</p>
                <a class="button button-primary" href="">@Localizer["Navigation_BackToHome"]</a>
            }
            else
            {
                <h2>@Localizer["Prepare_MethodQuestion"]</h2>
                <p>@Localizer["Prepare_BatchDescription", Math.Min(_overview.UnpreparedCount, AppSettings.PreparationLimit)]</p>
                <div class="method-grid">
                    <button type="button" class="method-card recommended" disabled="@_isBusy" @onclick="StartAutomaticAsync">
                        @if (_startingAutomatic)
                        {
                            <span class="preparation-transition-status">
                                <span class="transition-spinner" aria-hidden="true"></span>
                                <strong>@Localizer["Prepare_LoadingDictionaryData"]</strong>
                            </span>
                        }
                        else
                        {
                            <strong>@Localizer["Prepare_AutomaticOnline"]</strong>
                            <span>@Localizer["Prepare_AutomaticRecommended"]</span>
                        }
                    </button>
                    <button type="button" class="method-card" disabled="@_isBusy" @onclick="StartManualAsync">
                        <strong>@Localizer["Prepare_MethodManual"]</strong>
                        <span>@Localizer["Prepare_ManualDescription"]</span>
                    </button>
                </div>
                <button type="button" class="button button-secondary" disabled="@_isBusy" @onclick="CancelPreparation">
                    @Localizer["Common_Cancel"]
                </button>
            }
        </section>
    }
    else if (_item is not null)
    {
        <article class="preparation-card">
            <div class="review-progress">
                <span>@Localizer["Prepare_Progress", _item.Position, _item.TotalItems]</span>
                <progress value="@(_item.Position - 1)" max="@_item.TotalItems"></progress>
            </div>
            <p class="eyebrow">@Localizer["Prepare_Candidate"]</p>
            <h2 tabindex="-1" @ref="_candidateHeading">@_item.LearningTerm</h2>
            @if (_item.EncounteredSurfaceForm is { } encounteredSurfaceForm)
            {
                <p class="encountered-form">@Localizer["Prepare_InText", encounteredSurfaceForm]</p>
            }
            <dl class="preparation-details">
                <div><dt>@Localizer["Review_TokenKind"]</dt><dd>@GetTokenKindName(_item.TokenKind)</dd></div>
                <div><dt>@Localizer["Review_OccurrenceCount"]</dt><dd>@_item.AcceptedOccurrenceCount</dd></div>
            </dl>

            @if (CurrentContext is not null)
            {
                <section class="context-card">
                    <p><span>@CurrentContext.Text[..CurrentContext.TargetStart]</span><mark>@CurrentContext.Text.Substring(CurrentContext.TargetStart, CurrentContext.TargetLength)</mark><span>@CurrentContext.Text[(CurrentContext.TargetStart + CurrentContext.TargetLength)..]</span></p>
                    <small>@CurrentContext.DocumentTitle</small>
                    @if (_item.Contexts.Count > 1)
                    {
                        <div class="context-navigation">
                            <button type="button" class="button button-secondary" disabled="@(_contextIndex == 0 || _isBusy)" @onclick="PreviousContext">@Localizer["Review_PreviousContext"]</button>
                            <span>@Localizer["Review_ContextPosition", _contextIndex + 1, _item.Contexts.Count]</span>
                            <button type="button" class="button button-secondary" disabled="@(_contextIndex == _item.Contexts.Count - 1 || _isBusy)" @onclick="NextContext">@Localizer["Review_NextContext"]</button>
                        </div>
                    }
                </section>
            }

            @if (_isLookingUp)
            {
                <p class="loading-message preparation-transition-status" role="status">
                    <span class="transition-spinner" aria-hidden="true"></span>
                    <span>@Localizer["Prepare_LookingUp"]</span>
                </p>
            }
            else if (_item.Status == PreparationCandidateStatus.Failed && !_showEditor)
            {
                <div class="inline-message inline-message-error" role="alert" @ref="_lookupFailureRef">
                    <p>@GetLookupFailureMessage()</p>
                    <div class="button-row">
                        @if (CanRetryLookup)
                        {
                            <button type="button" class="button button-secondary" disabled="@_isBusy" @ref="_retryButtonRef" @onclick="RetryAsync">@Localizer["Common_TryAgain"]</button>
                        }
                        <button type="button" class="button button-secondary" disabled="@_isBusy" @ref="_manualEntryButtonRef" @onclick="EnableManualEntryAsync">@Localizer["Prepare_ManualEntry"]</button>
                    </div>
                    @if (IsDebugBuild
                        && _item.Result?.Status == LexicalLookupStatus.NotFound
                        && _item.Result.Diagnostics is { } diagnostics)
                    {
                        <details class="lookup-diagnostics">
                            <summary>@Localizer["Prepare_DebugLookupDetails"]</summary>
                            <dl>
                                <div><dt>@Localizer["Prepare_DebugDisplayedSurface"]</dt><dd>@diagnostics.DisplayedSurfaceForm</dd></div>
                                <div><dt>@Localizer["Prepare_DebugCanonicalTerm"]</dt><dd>@diagnostics.VocabularyCanonicalTerm</dd></div>
                                <div><dt>@Localizer["Prepare_DebugLookupTerm"]</dt><dd>@diagnostics.LookupTerm</dd></div>
                                <div><dt>@Localizer["Prepare_DebugSourceLanguage"]</dt><dd>@diagnostics.SourceLanguage</dd></div>
                                <div><dt>@Localizer["Prepare_DebugLookupMode"]</dt><dd>@diagnostics.LookupMode</dd></div>
                                <div><dt>@Localizer["Prepare_DebugTargetLanguage"]</dt><dd>@(diagnostics.TargetLanguage ?? "-")</dd></div>
                                <div><dt>@Localizer["Prepare_DebugCacheKey"]</dt><dd>@diagnostics.CacheKey</dd></div>
                                <div><dt>@Localizer["Prepare_DebugProviderRequest"]</dt><dd>@diagnostics.ProviderRequest</dd></div>
                                <div><dt>@Localizer["Prepare_DebugProviderOutcome"]</dt><dd>@diagnostics.ProviderOutcome</dd></div>
                            </dl>
                        </details>
                    }
                </div>
            }
            else if (_showEditor || _item.Method == PreparationMethod.Manual)
            {
                <div class="editor-grid" @ref="_editorRef">
                    <label>@Localizer["Prepare_CanonicalTerm"]<input class="text-input" @bind:event="oninput" @onkeydown="HandleInputKeyDown" readonly value="@_item.LearningTerm" /></label>
                    <label>@Localizer["Prepare_EncounteredForm"]<input class="text-input" @bind:event="oninput" @onkeydown="HandleInputKeyDown" readonly value="@(_item.EncounteredSurfaceForm ?? _item.Term)" /></label>
                    <label>
                        @Localizer["Prepare_AcronymExpansion"]
                        <input class="text-input"
                               @ref="_acronymExpansionInput"
                               @bind="AcronymExpansionInput"
                               @bind:event="oninput"
                               @onkeydown="HandleInputKeyDown"
                               aria-invalid="@_usefulAnswerMissing"
                               aria-describedby="@(_usefulAnswerMissing ? "prepare-useful-answer-error" : null)" />
                    </label>
                    <label>
                        @Localizer["Prepare_Translation"]
                        <input class="text-input"
                               @ref="_translationInput"
                               @bind="TranslationInput"
                               @bind:event="oninput"
                               @onkeydown="HandleInputKeyDown"
                               aria-invalid="@_usefulAnswerMissing"
                               aria-describedby="@(_usefulAnswerMissing ? "prepare-useful-answer-error" : null)" />
                    </label>
                    <label>
                        @Localizer["Prepare_Definition"]
                        <textarea class="text-area"
                                  rows="4"
                                  @ref="_definitionInput"
                                  @bind="DefinitionInput"
                                  @bind:event="oninput"
                                  aria-invalid="@_usefulAnswerMissing"
                                  aria-describedby="@(_usefulAnswerMissing ? "prepare-useful-answer-error" : null)"></textarea>
                    </label>
                    @if (_usefulAnswerMissing)
                    {
                        <p id="prepare-useful-answer-error"
                           class="field-error"
                           role="alert"
                           @ref="_usefulAnswerError">@Localizer["Prepare_UsefulAnswerRequired"]</p>
                    }
                    <label>@Localizer["Prepare_AdditionalNote"]<textarea class="text-area" rows="2" @bind="_additionalNote"></textarea></label>
                    <label>@Localizer["Prepare_AcceptedAliases"]<input class="text-input" @bind:event="oninput" @onkeydown="HandleInputKeyDown" @bind="_aliases" /></label>
                </div>

            }
            else if (_item.Result?.HasUsableData == true)
            {
                <section class="lexical-result">
                    @if (!string.IsNullOrWhiteSpace(_acronymExpansion))
                    {
                        <div><h3>@Localizer["Prepare_AcronymExpansion"]</h3><p>@_acronymExpansion</p></div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_translation))
                    {
                        <div><h3>@Localizer["Prepare_Translation"]</h3><p>@_translation</p></div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_definition))
                    {
                        <div><h3>@Localizer["Prepare_Definition"]</h3><p class="full-definition">@_definition</p></div>
                    }
                    @if (_item.Result.Meanings.Count > 1)
                    {
                        <p>@Localizer["Prepare_SeveralMeanings"]</p>
                        <button type="button"
                                class="meaning-picker-trigger"
                                aria-haspopup="dialog"
                                aria-expanded="@_isMeaningPickerOpen"
                                @ref="_meaningPickerButton"
                                disabled="@_isBusy"
                                @onclick="OpenMeaningPickerAsync">
                            <span>@MeaningPreviewPolicy.CreateClosedPreview(MeaningPreviewPolicy.GetPrimaryTextForMode(_definition, _translation, _item.Result.LookupMode))</span>
                        </button>
                    }
                    <SourceDetails ProviderName="@_item.Result.ProviderName"
                                   SourceProject="@_item.Result.SourceProject"
                                   PageTitle="@_item.Result.PageTitle"
                                   RevisionId="@_item.Result.RevisionId"
                                   Attribution="@_item.Result.Attribution" />
                </section>

            }

            @if (_confirmationAction is null && !_cancelConfirmationVisible)
            {
                <div class="preparation-disposition-actions" aria-label="@Localizer["Prepare_OtherActions"]">
                    <button type="button" class="button button-danger" disabled="@_isBusy" @ref="_markKnownButtonRef" @onclick="ShowMarkKnownConfirmation">@Localizer["Prepare_MarkKnown"]</button>
                    <button type="button" class="button button-danger" disabled="@_isBusy" @ref="_excludeButtonRef" @onclick="ShowExcludeConfirmation">@Localizer["Prepare_DoNotLearn"]</button>
                    <button type="button" class="button button-secondary" disabled="@_isBusy" @onclick="SkipAsync">@Localizer["Prepare_SkipForNow"]</button>
                </div>
            }
            else if (_confirmationAction is not null)
            {
                <section class="destructive-confirmation preparation-confirmation"
                         role="alertdialog"
                         aria-labelledby="preparation-confirmation-title"
                         @ref="_dispositionConfirmationRef"
                         @onkeydown="HandleDispositionKeyDown">
                    <h3 id="preparation-confirmation-title">@Localizer[_confirmationAction == PreparationCompletionAction.MarkKnown ? "Prepare_MarkKnown" : "Prepare_DoNotLearn"]</h3>
                    <p>@Localizer[_confirmationAction == PreparationCompletionAction.MarkKnown ? "Prepare_MarkKnownConfirmation" : "Prepare_DoNotLearnConfirmation"]</p>
                    <div class="button-row">
                        <button type="button" class="button button-secondary" disabled="@_isBusy" @ref="_dispositionCancelButtonRef" @onclick="CancelDispositionAsync">@Localizer["Common_Cancel"]</button>
                        <button type="button" class="button button-danger" data-destructive-confirm disabled="@_isBusy" @onclick="ConfirmDispositionAsync">@Localizer["Common_Confirm"]</button>
                    </div>
                </section>
            }

            @if (_confirmationAction is null)
            {
                <section class="preparation-cancel-section">
                    @if (!_cancelConfirmationVisible)
                    {
                        <button type="button" class="button button-danger cancel-preparation" disabled="@_isBusy" @ref="_cancelPreparationTriggerRef" @onclick="RequestCancelPreparationAsync">@Localizer["Prepare_CancelPreparation"]</button>
                    }
                    else
                    {
                        <div class="destructive-confirmation"
                             role="alertdialog"
                             aria-labelledby="cancel-preparation-confirmation-title"
                             @ref="_cancelConfirmationRef"
                             @onkeydown="HandleCancelPreparationDialogKeyDown">
                            <h3 id="cancel-preparation-confirmation-title">@Localizer["Prepare_CancelPreparation"]</h3>
                            <p>@Localizer["Prepare_CancelPreparationConfirmation"]</p>
                            <div class="button-row">
                                <button type="button" class="button button-secondary" disabled="@_isBusy" @ref="_cancelPreparationButtonRef" @onclick="CancelCancelPreparationAsync">@Localizer["Common_Cancel"]</button>
                                <button type="button" class="button button-danger" data-destructive-confirm disabled="@_isBusy" @onclick="ConfirmCancelPreparationAsync">@Localizer["Prepare_CancelPreparation"]</button>
                            </div>
                        </div>
                    }
                </section>
            }
            @if (_saveFailed)
            {
                <p class="inline-message inline-message-error" role="alert">@Localizer["Prepare_SaveError"]</p>
            }
        </article>
    }
    else
    {
        <section class="preparation-card" role="status">
            <h2>@Localizer["Prepare_BatchCompleteTitle"]</h2>
            <p>@Localizer["Prepare_BatchComplete", _overview.LastCompletedPreparedItems]</p>
            <div class="button-row">
                @if (_overview.PreparedNewItemCount > 0)
                {
                    <a class="button button-primary" href="learn">@Localizer["Prepare_StartLearning"]</a>
                }
                <a class="button button-secondary" href="settings">@Localizer["Prepare_ChangeLimit"]</a>
                <a class="button button-secondary" href="">@Localizer["Navigation_BackToHome"]</a>
            </div>
        </section>
    }
    </div>

    @if (_item is not null && _confirmationAction is null && !_cancelConfirmationVisible)
    {
        <div class="workflow-action-bar">
            <section class="preparation-action-bar">
                @if (_showEditor || _item.Method == PreparationMethod.Manual)
                {
                    <div class="button-row">
                        <button type="button" class="button button-primary" aria-keyshortcuts="Enter" disabled="@_isBusy" @onclick="AcceptAsync">@Localizer["Prepare_SaveAndContinue"]</button>
                        <button type="button" class="button button-secondary" disabled="@_isBusy" @onclick="CancelEditingAsync">@Localizer["Common_Cancel"]</button>
                    </div>
                }
                else if (_item.Result?.HasUsableData == true)
                {
                    <div class="button-row">
                        <button type="button" class="button button-primary" aria-keyshortcuts="Enter" disabled="@_isBusy" @onclick="AcceptAsync">
                            @if (_showTransitionSpinner)
                            {
                                <span class="transition-spinner" aria-hidden="true"></span>
                                <span>@Localizer["Prepare_Saving"]</span>
                            }
                            else
                            {
                                <span>@Localizer["Prepare_AcceptAndContinue"]</span>
                            }
                        </button>
                        <button type="button" class="button button-secondary" disabled="@_isBusy" @ref="_editButtonRef" @onclick="EnableEditingAsync">@Localizer["Prepare_Edit"]</button>
                    </div>
                }
            </section>
        </div>
    }
</section>

@if (_isMeaningPickerOpen && _item?.Result is { Meanings.Count: > 1 } result)
{
    <div class="meaning-picker-backdrop" @onclick="CloseMeaningPickerAsync">
        <section class="meaning-picker"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="meaning-picker-title"
                 tabindex="-1"
                 @ref="_meaningPickerDialog"
                 @onkeydown="HandleMeaningPickerKeyDown"
                 @onclick:stopPropagation="true">
            <header>
                <h2 id="meaning-picker-title">@Localizer["Prepare_ChooseAnotherMeaning"]</h2>
                <button type="button" class="button button-secondary" @onclick="CloseMeaningPickerAsync">@Localizer["Common_Close"]</button>
            </header>
            <ul class="meaning-options" role="listbox" aria-labelledby="meaning-picker-title">
                @foreach (var selectableMeaning in MeaningPreviewPolicy.GetSelectableMeanings(result.Meanings, result.LookupMode))
                {
                    var meaningIndex = selectableMeaning.OriginalIndex;
                    <li role="none" class="meaning-option @(_selectedMeaningIndex == meaningIndex ? "selected" : null)">
                        <button type="button"
                                role="option"
                                aria-selected="@(_selectedMeaningIndex == meaningIndex)"
                                @onclick="() => SelectMeaningAsync(meaningIndex)">
                            @if (!string.IsNullOrWhiteSpace(selectableMeaning.SecondaryText))
                            {
                                <small class="meaning-secondary">@selectableMeaning.SecondaryText</small>
                            }
                            <span class="meaning-primary">@selectableMeaning.PrimaryText</span>
                        </button>
                        @if (selectableMeaning.IsTruncated)
                        {
                            <details>
                                <summary>@Localizer["Common_ShowFullText"]</summary>
                                <p>@selectableMeaning.FullText</p>
                            </details>
                        }
                    </li>
                }
            </ul>
        </section>
    </div>
}

@code {
    private PreparationOverview _overview = new(0, 0, 0, null, 0, 0, null, 0);
    private PreparationItem? _item;
    private bool _isLoading = true;
    private bool _isBusy;
    private bool _isLookingUp;
    private bool _loadFailed;
    private bool _saveFailed;
    private bool _showPrivacyDisclosure;
    private bool _showEditor;
    private bool _usefulAnswerMissing;
    private bool _batchCompleted;
    private bool _isMeaningPickerOpen;
    private bool _showTransitionSpinner;
    private bool _cancelConfirmationVisible;
    private bool _startingAutomatic;
    private bool _revealLookupFailure;
    private bool _editorOpenedFromLookupFailure;
    private int _contextIndex;
    private int _selectedMeaningIndex;
    private string _acronymExpansion = string.Empty;
    private string _translation = string.Empty;
    private string _definition = string.Empty;
    private string _additionalNote = string.Empty;
    private string _aliases = string.Empty;
    private CancellationTokenSource? _lookupCancellation;
    private CancellationTokenSource? _transitionSpinnerCancellation;
    private IDisposable? _meaningPickerBackRegistration;
    private ElementReference _meaningPickerButton;
    private ElementReference _meaningPickerDialog;
    private ElementReference _candidateHeading;
    private ElementReference _lookupFailureRef;
    private ElementReference _retryButtonRef;
    private ElementReference _manualEntryButtonRef;
    private ElementReference _editorRef;
    private ElementReference _editButtonRef;
    private ElementReference _markKnownButtonRef;
    private ElementReference _excludeButtonRef;
    private ElementReference _dispositionConfirmationRef;
    private ElementReference _dispositionCancelButtonRef;
    private ElementReference _cancelPreparationTriggerRef;
    private ElementReference _cancelConfirmationRef;
    private ElementReference _cancelPreparationButtonRef;
    private ElementReference _acronymExpansionInput;
    private ElementReference _translationInput;
    private ElementReference _definitionInput;
    private ElementReference _usefulAnswerError;
    private PreparationCompletionAction? _confirmationAction;

    private string AcronymExpansionInput
    {
        get => _acronymExpansion;
        set
        {
            _acronymExpansion = value;
            ClearUsefulAnswerValidationIfCorrected();
        }
    }

    private string TranslationInput
    {
        get => _translation;
        set
        {
            _translation = value;
            ClearUsefulAnswerValidationIfCorrected();
        }
    }

    private string DefinitionInput
    {
        get => _definition;
        set
        {
            _definition = value;
            ClearUsefulAnswerValidationIfCorrected();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_revealLookupFailure || _isBusy || _isLookingUp || _isLoading)
        {
            return;
        }

        _revealLookupFailure = false;
        await RevealLookupFailureAsync();
    }

    private PreparationContext? CurrentContext => _item is null || _item.Contexts.Count == 0
        ? null
        : _item.Contexts[_contextIndex];

    private bool CanRetryLookup => _item?.Result is { } result
        && LexicalLookupOutcomePolicy.CanRetry(result.Status, result.ErrorCode);

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadFailed = false;
        try
        {
            _overview = await PreparationService.GetOverviewAsync();
            _item = await PreparationService.GetCurrentAsync();
            InitializeFields();
            if (_item is { Method: PreparationMethod.AutomaticOnline, Status: PreparationCandidateStatus.Pending })
            {
                await LookupAsync();
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "The preparation workflow could not be loaded.");
            _loadFailed = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task StartAutomaticAsync()
    {
        if (!AppSettings.HasOnlineLookupConsent)
        {
            _showPrivacyDisclosure = true;
            return;
        }

        _startingAutomatic = true;
        try
        {
            await StartAsync(PreparationMethod.AutomaticOnline);
        }
        finally
        {
            _startingAutomatic = false;
        }
    }

    private async Task ConfirmOnlineLookupAsync()
    {
        AppSettings.GrantOnlineLookupConsent();
        _showPrivacyDisclosure = false;
        await StartAsync(PreparationMethod.AutomaticOnline);
    }

    private Task StartManualAsync()
    {
        _showPrivacyDisclosure = false;
        return StartAsync(PreparationMethod.Manual);
    }

    private async Task StartAsync(PreparationMethod method)
    {
        if (_isBusy)
        {
            return;
        }

        _isBusy = true;
        _saveFailed = false;
        try
        {
            await PreparationService.StartAsync(method, AppSettings.PreparationLimit);
            _overview = await PreparationService.GetOverviewAsync();
            _item = await PreparationService.GetCurrentAsync();
            InitializeFields();
            if (method == PreparationMethod.AutomaticOnline && _item is not null)
            {
                await LookupAsync();
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "The preparation batch could not be started.");
            _saveFailed = true;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task LookupAsync()
    {
        _lookupCancellation?.Cancel();
        _lookupCancellation?.Dispose();
        var cancellation = new CancellationTokenSource();
        _lookupCancellation = cancellation;
        _isLookingUp = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            _item = await PreparationService.LookupCurrentAsync(cancellation.Token);
            InitializeFields();
        }
        catch (OperationCanceledException) when (cancellation.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_lookupCancellation, cancellation))
            {
                _lookupCancellation = null;
                _isLookingUp = false;
                _revealLookupFailure = _item?.Status == PreparationCandidateStatus.Failed;
            }

            cancellation.Dispose();
        }
    }

    private async Task RetryAsync()
    {
        if (_isBusy || !CanRetryLookup)
        {
            return;
        }

        _isBusy = true;
        _saveFailed = false;
        try
        {
            await LookupAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "The dictionary lookup retry failed.");
            _saveFailed = true;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task OpenMeaningPickerAsync()
    {
        if (_isBusy || _isMeaningPickerOpen)
        {
            return;
        }

        _isMeaningPickerOpen = true;
        _meaningPickerBackRegistration = NavigationHistory.RegisterDismissibleOverlay(
            () => _ = InvokeAsync(() => CloseMeaningPickerAsync()));
        await InvokeAsync(StateHasChanged);
        await JavaScript.InvokeVoidAsync("knownFirst.focusElement", _meaningPickerDialog);
    }

    private async Task CloseMeaningPickerAsync()
    {
        if (!_isMeaningPickerOpen)
        {
            return;
        }

        _meaningPickerBackRegistration?.Dispose();
        _meaningPickerBackRegistration = null;
        _isMeaningPickerOpen = false;
        await InvokeAsync(StateHasChanged);
        await JavaScript.InvokeVoidAsync("knownFirst.focusElement", _meaningPickerButton);
    }

    private Task HandleMeaningPickerKeyDown(KeyboardEventArgs eventArgs) =>
        string.Equals(eventArgs.Key, "Escape", StringComparison.Ordinal)
            ? CloseMeaningPickerAsync()
            : Task.CompletedTask;

    private async Task SelectMeaningAsync(int meaningIndex)
    {
        if (_item?.Result is null || _isBusy)
        {
            return;
        }

        _selectedMeaningIndex = meaningIndex;
        await PreparationService.SelectMeaningAsync(_item.CandidateId, meaningIndex);
        ApplyMeaning(_item.Result.Meanings[meaningIndex]);
        await CloseMeaningPickerAsync();
    }

    private async Task AcceptAsync()
    {
        if (_item is null || _isBusy)
        {
            return;
        }

        if (!HasUsefulAnswer())
        {
            await ShowUsefulAnswerValidationAsync();
            return;
        }

        _usefulAnswerMissing = false;

        var acceptedCandidateId = _item.CandidateId;
        var transitionStarted = System.Diagnostics.Stopwatch.StartNew();
        _isBusy = true;
        _saveFailed = false;
        StartDelayedTransitionSpinner();
        try
        {
            var result = _item.Result;
            var selectedMeaning = result is not null && result.Meanings.Count > _selectedMeaningIndex
                ? result.Meanings[_selectedMeaningIndex]
                : null;
            await PreparationService.AcceptAsync(
                _item.CandidateId,
                new PreparedMeaningInput(
                    selectedMeaning?.MeaningId,
                    EmptyToNull(_acronymExpansion),
                    EmptyToNull(_translation),
                    _definition,
                    selectedMeaning?.Example,
                    EmptyToNull(_additionalNote),
                    _aliases.Split([',', ';'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries),
                    result?.ProviderName ?? "Manual",
                    result?.SourceProject ?? string.Empty,
                    result?.PageTitle ?? string.Empty,
                    result?.RevisionId,
                    result?.Attribution ?? string.Empty,
                    _item.EncounteredSurfaceForm,
                    result?.GrammaticalRelationship,
                    result?.DisplayTerm ?? _item.Term),
                AppSettings.CardDirection);
            await MoveNextAsync();
#if DEBUG
            PreparationService.RecordUiTransition(acceptedCandidateId, transitionStarted.Elapsed);
#endif
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "The prepared learning item could not be saved.");
            _saveFailed = true;
        }
        finally
        {
            StopTransitionSpinner();
            _isBusy = false;
        }
    }

    private async Task SkipAsync()
    {
        if (_item is null || _isBusy)
        {
            return;
        }

        _isBusy = true;
        _saveFailed = false;
        try
        {
            await PreparationService.SkipAsync(_item.CandidateId);
            await MoveNextAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "The preparation item could not be skipped.");
            _saveFailed = true;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ConfirmDispositionAsync()
    {
        if (_item is null || _isBusy || _confirmationAction is null)
        {
            return;
        }

        var action = _confirmationAction.Value;
        _isBusy = true;
        _saveFailed = false;
        try
        {
            if (action == PreparationCompletionAction.MarkKnown)
            {
                await PreparationService.MarkKnownAsync(_item.CandidateId);
            }
            else
            {
                await PreparationService.ExcludeAsync(_item.CandidateId);
            }

            _confirmationAction = null;
            await MoveNextAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "The preparation disposition could not be saved.");
            _saveFailed = true;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task MoveNextAsync()
    {
        var method = _item?.Method;
        _contextIndex = 0;
        if (method == PreparationMethod.AutomaticOnline)
        {
            await LookupAsync();
        }
        else
        {
            _item = await PreparationService.GetCurrentAsync();
            InitializeFields();
        }

        if (_item is null)
        {
            _overview = await PreparationService.GetOverviewAsync();
            _batchCompleted = true;
        }
        else
        {
            await InvokeAsync(StateHasChanged);
            await JavaScript.InvokeVoidAsync("knownFirst.revealElement", _candidateHeading);
            await JavaScript.InvokeVoidAsync("knownFirst.focusElement", _candidateHeading);
        }
    }

    private void InitializeFields()
    {
        _showEditor = _item?.Method == PreparationMethod.Manual;
        _editorOpenedFromLookupFailure = false;
        _revealLookupFailure = false;
        _usefulAnswerMissing = false;
        _confirmationAction = null;
        _cancelConfirmationVisible = false;
        _selectedMeaningIndex = _item?.SelectedMeaningIndex ?? 0;
        _acronymExpansion = _item?.Result?.AcronymExpansion ?? string.Empty;
        _translation = string.Empty;
        _definition = string.Empty;
        _additionalNote = string.Empty;
        _aliases = string.Empty;
        if (_item?.Result is { Meanings.Count: > 0 } result)
        {
            _selectedMeaningIndex = Math.Clamp(_selectedMeaningIndex, 0, result.Meanings.Count - 1);
            ApplyMeaning(result.Meanings[_selectedMeaningIndex]);
        }
    }

    private void ApplyMeaning(LexicalMeaning meaning)
    {
        _translation = meaning.Translation ?? string.Empty;
        _definition = meaning.Definition;
    }

    private bool HasUsefulAnswer() => !string.IsNullOrWhiteSpace(_acronymExpansion)
        || !string.IsNullOrWhiteSpace(_translation)
        || !string.IsNullOrWhiteSpace(_definition);

    private async Task ShowUsefulAnswerValidationAsync()
    {
        _usefulAnswerMissing = true;
        await InvokeAsync(StateHasChanged);
        await JavaScript.InvokeVoidAsync("knownFirst.revealElement", _usefulAnswerError);
        await JavaScript.InvokeVoidAsync("knownFirst.focusElement", GetUsefulAnswerFocusTarget());
    }

    private ElementReference GetUsefulAnswerFocusTarget() => _item?.TokenKind is TokenKind.Acronym or TokenKind.Abbreviation
        ? _acronymExpansionInput
        : _item?.LookupMode == LexicalLookupMode.Translation
            ? _translationInput
            : _definitionInput;

    private void ClearUsefulAnswerValidationIfCorrected()
    {
        if (_usefulAnswerMissing && HasUsefulAnswer())
        {
            _usefulAnswerMissing = false;
        }
    }

    private string GetLookupFailureMessage()
    {
        var result = _item?.Result;
        return result?.ErrorCode switch
        {
            "missing-page" => Localizer["Prepare_DictionaryEntryNotFound"],
            "definition-not-found" or "no-suitable-direct-sense" =>
                Localizer["Prepare_DefinitionNotFound"],
            "translation-not-found" => Localizer["Prepare_TranslationNotFound"],
            "language-section-not-found" => Localizer["Prepare_LanguageSectionNotFound"],
            "network-unavailable" or "timeout" or "transient-server-error" =>
                Localizer["Prepare_NetworkFailure"],
            "rate-limited" => Localizer["Prepare_RateLimited"],
            "malformed-json" or "missing-parse-payload" or "missing-html" =>
                Localizer["Prepare_ResponseParseFailure"],
            _ => result?.Status switch
            {
                LexicalLookupStatus.TransientFailure => Localizer["Prepare_TransientFailure"],
                LexicalLookupStatus.ParseFailure => Localizer["Prepare_ParseFailure"],
                LexicalLookupStatus.PermanentFailure => Localizer["Prepare_PermanentFailure"],
                _ => Localizer["Prepare_NotFound"]
            }
        };
    }

    private string GetTokenKindName(TokenKind kind) => kind switch
    {
        TokenKind.Acronym => Localizer["TokenKind_Acronym"],
        TokenKind.Abbreviation => Localizer["TokenKind_Abbreviation"],
        TokenKind.TechnicalTerm => Localizer["TokenKind_TechnicalTerm"],
        _ => Localizer["TokenKind_Word"]
    };

    private async Task EnableEditingAsync()
    {
        _editorOpenedFromLookupFailure = false;
        _showEditor = true;
        await RevealEditorAsync();
    }

    private async Task EnableManualEntryAsync()
    {
        _editorOpenedFromLookupFailure = true;
        _showEditor = true;
        if (_item?.Result?.HasUsableData != true)
        {
            _definition = string.Empty;
        }

        await RevealEditorAsync();
    }

    private async Task CancelEditingAsync()
    {
        var openedFromLookupFailure = _editorOpenedFromLookupFailure;
        InitializeFields();
        await InvokeAsync(StateHasChanged);

        if (_item?.Method == PreparationMethod.Manual)
        {
            await JavaScript.InvokeVoidAsync("knownFirst.focusElement", GetUsefulAnswerFocusTarget());
            return;
        }

        await JavaScript.InvokeVoidAsync(
            "knownFirst.focusElement",
            openedFromLookupFailure ? _manualEntryButtonRef : _editButtonRef);
    }

    private Task ShowMarkKnownConfirmation() =>
        ShowDispositionConfirmationAsync(PreparationCompletionAction.MarkKnown);

    private Task ShowExcludeConfirmation() =>
        ShowDispositionConfirmationAsync(PreparationCompletionAction.Exclude);

    private async Task ShowDispositionConfirmationAsync(PreparationCompletionAction action)
    {
        _confirmationAction = action;
        await InvokeAsync(StateHasChanged);
        await JavaScript.InvokeVoidAsync("knownFirst.revealElement", _dispositionConfirmationRef);
        await JavaScript.InvokeVoidAsync("knownFirst.focusElement", _dispositionCancelButtonRef);
    }

    private async Task CancelDispositionAsync()
    {
        var action = _confirmationAction;
        _confirmationAction = null;
        await InvokeAsync(StateHasChanged);

        if (action is not null)
        {
            await JavaScript.InvokeVoidAsync("knownFirst.focusElement", GetDispositionTrigger(action.Value));
        }
    }

    private ElementReference GetDispositionTrigger(PreparationCompletionAction action) =>
        action == PreparationCompletionAction.MarkKnown ? _markKnownButtonRef : _excludeButtonRef;

    private Task HandleDispositionKeyDown(KeyboardEventArgs eventArgs) =>
        IsEscape(eventArgs) ? CancelDispositionAsync() : Task.CompletedTask;

    private async Task RevealEditorAsync()
    {
        await InvokeAsync(StateHasChanged);
        await JavaScript.InvokeVoidAsync("knownFirst.revealElement", _editorRef);
        await JavaScript.InvokeVoidAsync("knownFirst.focusElement", GetUsefulAnswerFocusTarget());
    }

    private async Task RevealLookupFailureAsync()
    {
        await JavaScript.InvokeVoidAsync("knownFirst.revealElement", _lookupFailureRef);
        await JavaScript.InvokeVoidAsync(
            "knownFirst.focusElement",
            CanRetryLookup ? _retryButtonRef : _manualEntryButtonRef);
    }

    private void PreviousContext() => _contextIndex = Math.Max(0, _contextIndex - 1);

    private void NextContext()
    {
        if (_item is not null)
        {
            _contextIndex = Math.Min(_item.Contexts.Count - 1, _contextIndex + 1);
        }
    }

    private void StartDelayedTransitionSpinner()
    {
        StopTransitionSpinner();
        var cancellation = new CancellationTokenSource();
        _transitionSpinnerCancellation = cancellation;
        _ = ShowTransitionSpinnerAfterDelayAsync(cancellation);
    }

    private async Task ShowTransitionSpinnerAfterDelayAsync(CancellationTokenSource cancellation)
    {
        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(150), cancellation.Token);
            if (ReferenceEquals(_transitionSpinnerCancellation, cancellation) && _isBusy)
            {
                _showTransitionSpinner = true;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void StopTransitionSpinner()
    {
        _transitionSpinnerCancellation?.Cancel();
        _transitionSpinnerCancellation?.Dispose();
        _transitionSpinnerCancellation = null;
        _showTransitionSpinner = false;
    }

    private void CancelDisclosure() => _showPrivacyDisclosure = false;

    private async Task RequestCancelPreparationAsync()
    {
        if (_isBusy)
        {
            return;
        }

        if (_overview.ActiveCompletedItems > 0 || (_item?.Position ?? 1) > 1)
        {
            _cancelConfirmationVisible = true;
            await InvokeAsync(StateHasChanged);
            await JavaScript.InvokeVoidAsync("knownFirst.revealElement", _cancelConfirmationRef);
            await JavaScript.InvokeVoidAsync("knownFirst.focusElement", _cancelPreparationButtonRef);
            return;
        }

        await ConfirmCancelPreparationAsync();
    }

    private async Task ConfirmCancelPreparationAsync()
    {
        if (_isBusy)
        {
            return;
        }

        _isBusy = true;
        _lookupCancellation?.Cancel();
        try
        {
            await PreparationService.CancelActiveSessionAsync();
            _cancelConfirmationVisible = false;
            _confirmationAction = null;
            _isMeaningPickerOpen = false;
            _saveFailed = false;
            _item = null;
            Navigation.NavigateTo(string.Empty);
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "The preparation batch could not be cancelled.");
            _saveFailed = true;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task CancelCancelPreparationAsync()
    {
        _cancelConfirmationVisible = false;
        await InvokeAsync(StateHasChanged);
        await JavaScript.InvokeVoidAsync("knownFirst.focusElement", _cancelPreparationTriggerRef);
    }

    private Task HandleCancelPreparationDialogKeyDown(KeyboardEventArgs eventArgs) =>
        IsEscape(eventArgs) ? CancelCancelPreparationAsync() : Task.CompletedTask;

    private void CancelPreparation() => Navigation.NavigateTo(string.Empty);

    public async ValueTask DisposeAsync()
    {
        _meaningPickerBackRegistration?.Dispose();
        _lookupCancellation?.Cancel();
        _lookupCancellation?.Dispose();
        _lookupCancellation = null;
        StopTransitionSpinner();
        await PreparationService.CancelPrefetchAsync();
    }

    private static string? EmptyToNull(string value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static bool IsDebugBuild
    {
        get
        {
#if DEBUG
            return true;
#else
            return false;
#endif
        }
    }

    private Task HandleInputKeyDown(KeyboardEventArgs eventArgs)
    {
        if (string.Equals(eventArgs.Key, "Enter", StringComparison.Ordinal))
        {
            return AcceptAsync();
        }
        return Task.CompletedTask;
    }

    private Task HandleKeyDown(KeyboardEventArgs eventArgs)
    {
        if (IsEscape(eventArgs) && _confirmationAction is not null)
        {
            return CancelDispositionAsync();
        }

        if (IsEscape(eventArgs) && _cancelConfirmationVisible)
        {
            return CancelCancelPreparationAsync();
        }

        if (string.Equals(eventArgs.Key, "Enter", StringComparison.Ordinal)
            && !_isBusy
            && _item is not null
            && !_cancelConfirmationVisible
            && !_isMeaningPickerOpen
            && _confirmationAction is null)
        {
            if (_showEditor || _item.Method == PreparationMethod.Manual || _item.Result?.HasUsableData == true)
            {
                return AcceptAsync();
            }
        }
        return Task.CompletedTask;
    }

    private static bool IsEscape(KeyboardEventArgs eventArgs) =>
        string.Equals(eventArgs.Key, "Escape", StringComparison.Ordinal)
        || string.Equals(eventArgs.Key, "Esc", StringComparison.Ordinal);

    private enum PreparationCompletionAction
    {
        MarkKnown,
        Exclude
    }
}
