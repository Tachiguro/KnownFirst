@page "/"
@inject IDashboardService DashboardService
@inject ITextReviewService TextReviewService
@inject ILogger<Home> Logger
@inject KnownFirst.Services.Study.IWorkflowStateService WorkflowState

<PageTitle>@Localizer["Home_Title"]</PageTitle>

<section class="home-hero">
    <p class="eyebrow">@Localizer["App_Name"]</p>
    <h1>@Localizer["Home_Title"]</h1>
    <p class="subtitle">@Localizer["Home_Subtitle"]</p>
</section>

@if (_activeReview is not null)
{
    <section class="continue-review-card" aria-labelledby="continue-review-title">
        <div>
            <p class="eyebrow">@Localizer["Home_ReviewInProgress"]</p>
            <h2 id="continue-review-title">@Localizer["Home_ContinueReviewTitle"]</h2>
            <p>@Localizer["Home_ContinueReviewDescription", _activeReview.DocumentTitle]</p>
            <strong>@Localizer["Home_ReviewProgress", _activeReview.ReviewedCount, _activeReview.TotalCandidates]</strong>
        </div>
        <div class="continue-review-actions">
            <a class="button button-primary" href="review-words">@Localizer["Home_ContinueReviewAction"]</a>
            @if (!_showDiscardConfirmation)
            {
                <button type="button" class="button button-danger" disabled="@_isDiscarding" @onclick="ShowDiscardConfirmation">
                    @Localizer["Review_DiscardAction"]
                </button>
            }
        </div>

        @if (_showDiscardConfirmation)
        {
            <div class="home-discard-confirmation" role="alertdialog" aria-labelledby="home-discard-title">
                <h3 id="home-discard-title">@Localizer["Review_DiscardTitle"]</h3>
                <p>@Localizer["Review_DiscardMessage"]</p>
                <div class="continue-review-actions">
                    <button type="button" class="button button-secondary" disabled="@_isDiscarding" @onclick="CancelDiscard">
                        @Localizer["Common_Cancel"]
                    </button>
                    <button type="button" class="button button-danger" disabled="@_isDiscarding" @onclick="DiscardAsync">
                        @Localizer["Review_DiscardConfirm"]
                    </button>
                </div>
            </div>
        }

        @if (_discardFailed)
        {
            <p class="inline-message inline-message-error" role="alert">@Localizer["Review_DiscardError"]</p>
        }
    </section>
}

<section class="action-grid">
    @if (_workflow.CanLearn)
    {
        <a class="action-card" href="learn">@Localizer["Navigation_Learn"]<span aria-hidden="true">→</span></a>
    }
    else
    {
        <div class="action-card blocked" aria-disabled="true" title="@(Localizer["Navigation_LearnUnavailable"])">
            <span class="action-card-label">@Localizer["Navigation_Learn"]</span>
            <small>@Localizer["Navigation_LearnUnavailable"]</small>
        </div>
    }
    @if (_workflow.CanImport)
    {
        <a class="action-card" href="import-text">@Localizer["Navigation_ImportText"]<span aria-hidden="true">→</span></a>
    }
    else
    {
        <div class="action-card blocked" aria-disabled="true" title="@(Localizer["Navigation_ImportBlockedByReview"])">
            <span class="action-card-label">@Localizer["Navigation_ImportText"]</span>
            <small>@Localizer["Navigation_ImportBlockedByReview"]</small>
        </div>
    }
    @if (_workflow.PrimaryAction is WorkflowPrimaryAction.ContinuePreparation or WorkflowPrimaryAction.PrepareWords)
    {
        <a class="action-card" href="prepare-words">
            @Localizer[_workflow.HasActivePreparation ? "Home_ContinuePreparation" : "Navigation_PrepareWords"]
            <span aria-hidden="true">→</span>
        </a>
    }
    <a class="action-card" href="settings">@Localizer["Navigation_Settings"]<span aria-hidden="true">→</span></a>
</section>

@if (_isLoading)
{
    <p class="loading-message" role="status">@Localizer["Home_LoadingStatistics"]</p>
}
else if (_loadFailed)
{
    <div class="inline-message inline-message-error" role="alert">
        <span>@Localizer["Home_DashboardError"]</span>
        <button class="button button-secondary" @onclick="LoadStatisticsAsync">@Localizer["Common_Retry"]</button>
    </div>
}
else
{
    <section class="statistics-grid">
        <article class="statistic-card">
            <strong>@_statistics.DocumentCount</strong>
            <span>@Localizer["Home_ImportedTexts"]</span>
        </article>
        <article class="statistic-card">
            <strong>@_statistics.UnreviewedWordCount</strong>
            <span>@Localizer["Home_WordsToReview"]</span>
        </article>
        <article class="statistic-card">
            <strong>@_statistics.KnownWordCount</strong>
            <span>@Localizer["Home_KnownWords"]</span>
        </article>
        <article class="statistic-card">
            <strong>@_statistics.UnknownBacklogWordCount</strong>
            <span>@Localizer["Home_UnknownWords"]</span>
        </article>
        <article class="statistic-card">
            <strong>@_statistics.PreparedAndLearningWordCount</strong>
            <span>@Localizer["Home_PreparedWords"]</span>
        </article>
    </section>
}

@code {
    private DashboardStatistics _statistics = DashboardStatistics.Empty;
    private ActiveReviewSummary? _activeReview;
    private WorkflowSnapshot _workflow = new(
        false,
        false,
        false,
        0,
        0,
        0,
        WorkflowPrimaryAction.ImportText);
    private bool _isLoading = true;
    private bool _loadFailed;
    private bool _showDiscardConfirmation;
    private bool _isDiscarding;
    private bool _discardFailed;

    private bool IsReviewBlocked => _activeReview is not null;

    protected override Task OnInitializedAsync() => LoadStatisticsAsync();

    private async Task LoadStatisticsAsync()
    {
        _isLoading = true;
        _loadFailed = false;

        try
        {
            _statistics = await DashboardService.GetStatisticsAsync();
            _activeReview = await TextReviewService.GetActiveReviewAsync();
            _workflow = await WorkflowState.GetSnapshotAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Dashboard statistics could not be loaded.");
            _loadFailed = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ShowDiscardConfirmation()
    {
        _discardFailed = false;
        _showDiscardConfirmation = true;
    }

    private void CancelDiscard() => _showDiscardConfirmation = false;

    private async Task DiscardAsync()
    {
        if (_isDiscarding)
        {
            return;
        }

        _isDiscarding = true;
        _discardFailed = false;
        try
        {
            await TextReviewService.DiscardActiveImportAsync();
            _showDiscardConfirmation = false;
            await LoadStatisticsAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "The unfinished text import could not be discarded from Home.");
            _discardFailed = true;
        }
        finally
        {
            _isDiscarding = false;
        }
    }
}
