@page "/settings"
@inject ILanguageSelectionService LanguageSelection
@inject IThemeService ThemeService
@inject IAppSettingsService AppSettings
@inject ISettingsFeedbackService SettingsFeedback
@inject KnownFirst.Data.IKnownFirstDatabase Database
@inject ILogger<Settings> Logger
@inject IJSRuntime JsRuntime
@inject ITextReviewService TextReviewService
@inject KnownFirst.Services.Lexical.ILexicalDiagnosticLog LexicalDiagnosticLog

<PageTitle>@Localizer["Settings_Title"]</PageTitle>

<section class="settings-page">
    <PageHeader Title="@(Localizer["Settings_Title"])"
                BackHref="@(_hasActiveReview ? "review-words" : string.Empty)" />

    @if (_hasActiveReview)
    {
        <a class="button button-secondary" href="review-words">@Localizer["Settings_ReturnToReview"]</a>
    }

    <section class="settings-card" aria-labelledby="language-setting-title">
        <h2 id="language-setting-title">@Localizer["Settings_UILanguage"]</h2>
        <div class="choice-grid choice-grid-two">
            <button type="button"
                    class="choice-button @(IsLanguageSelected(LanguageSelectionService.EnglishLanguageCode) ? "active" : null)"
                    aria-pressed="@IsLanguageSelected(LanguageSelectionService.EnglishLanguageCode)"
                    disabled="@_isChangingLanguage"
                    @onclick="() => SelectUiLanguage(LanguageSelectionService.EnglishLanguageCode)">
                @Localizer["Settings_English"]
            </button>
            <button type="button"
                    class="choice-button @(IsLanguageSelected(LanguageSelectionService.GermanLanguageCode) ? "active" : null)"
                    aria-pressed="@IsLanguageSelected(LanguageSelectionService.GermanLanguageCode)"
                    disabled="@_isChangingLanguage"
                    @onclick="() => SelectUiLanguage(LanguageSelectionService.GermanLanguageCode)">
                @Localizer["Settings_German"]
            </button>
        </div>
        @if (_languageConfirmation is not null)
        {
            <p class="setting-feedback setting-feedback-success" role="status" aria-live="polite">
                @Localizer[_languageConfirmation == LanguageSelectionService.GermanLanguageCode
                    ? "Settings_LanguageChangedToGerman"
                    : "Settings_LanguageChangedToEnglish"]
            </p>
        }
        else if (_languageChangeFailed)
        {
            <p class="setting-feedback setting-feedback-error" role="alert">@Localizer["Settings_SaveError"]</p>
        }
    </section>

    <section class="settings-card" aria-labelledby="appearance-setting-title">
        <h2 id="appearance-setting-title">@Localizer["Settings_Appearance"]</h2>
        <div class="choice-grid choice-grid-three">
            <button type="button"
                    class="choice-button @(IsThemeSelected(ThemePreference.System) ? "active" : null)"
                    aria-pressed="@IsThemeSelected(ThemePreference.System)"
                    @onclick="() => SelectTheme(ThemePreference.System)">
                @Localizer["Settings_AppearanceSystem"]
            </button>
            <button type="button"
                    class="choice-button @(IsThemeSelected(ThemePreference.Light) ? "active" : null)"
                    aria-pressed="@IsThemeSelected(ThemePreference.Light)"
                    @onclick="() => SelectTheme(ThemePreference.Light)">
                @Localizer["Settings_AppearanceLight"]
            </button>
            <button type="button"
                    class="choice-button @(IsThemeSelected(ThemePreference.Dark) ? "active" : null)"
                    aria-pressed="@IsThemeSelected(ThemePreference.Dark)"
                    @onclick="() => SelectTheme(ThemePreference.Dark)">
                @Localizer["Settings_AppearanceDark"]
            </button>
        </div>
        @if (_appearanceConfirmation is not null)
        {
            <p class="setting-feedback setting-feedback-success" role="status" aria-live="polite">
                @Localizer["Settings_AppearanceChangedTo", GetAppearanceDisplayName(_appearanceConfirmation.Value)]
            </p>
        }
        else if (_appearanceChangeFailed)
        {
            <p class="setting-feedback setting-feedback-error" role="alert">@Localizer["Settings_SaveError"]</p>
        }
    </section>

    <section class="settings-card" aria-labelledby="preparation-limit-title">
        <h2 id="preparation-limit-title">
            <label for="preparation-limit">@Localizer["Settings_PreparationLimit"]</label>
        </h2>
        <p id="preparation-limit-help" class="setting-help">@Localizer["Settings_PreparationLimitHelp"]</p>
        <div class="field-group">
            <select id="preparation-limit"
                    aria-describedby="preparation-limit-help"
                    @bind="_selectedPreparationLimit"
                    @bind:after="SavePreparationLimit">
                @foreach (var limit in AppSettings.SupportedPreparationLimits)
                {
                    <option value="@limit">@limit</option>
                }
            </select>
        </div>
        @if (_preparationLimitConfirmation is not null)
        {
            <p class="setting-feedback setting-feedback-success" role="status" aria-live="polite">
                @Localizer["Settings_PreparationLimitSaved", _preparationLimitConfirmation.Value]
            </p>
        }
        else if (_preparationLimitChangeFailed)
        {
            <p class="setting-feedback setting-feedback-error" role="alert">@Localizer["Settings_SaveError"]</p>
        }
    </section>

    <section class="settings-card" aria-labelledby="card-direction-title">
        <h2 id="card-direction-title">@Localizer["Settings_CardDirection"]</h2>
        <div class="choice-grid choice-grid-three">
            <button type="button"
                    class="choice-button @(_selectedCardDirection == CardDirectionPreference.TermToMeaning ? "active" : null)"
                    aria-pressed="@(_selectedCardDirection == CardDirectionPreference.TermToMeaning)"
                    @onclick="() => SelectCardDirection(CardDirectionPreference.TermToMeaning)">
                @Localizer["Settings_CardDirectionTermToMeaning"]
            </button>
            <button type="button"
                    class="choice-button @(_selectedCardDirection == CardDirectionPreference.MeaningToTerm ? "active" : null)"
                    aria-pressed="@(_selectedCardDirection == CardDirectionPreference.MeaningToTerm)"
                    @onclick="() => SelectCardDirection(CardDirectionPreference.MeaningToTerm)">
                @Localizer["Settings_CardDirectionMeaningToTerm"]
            </button>
            <button type="button"
                    class="choice-button @(_selectedCardDirection == CardDirectionPreference.Both ? "active" : null)"
                    aria-pressed="@(_selectedCardDirection == CardDirectionPreference.Both)"
                    @onclick="() => SelectCardDirection(CardDirectionPreference.Both)">
                @Localizer["Settings_CardDirectionBoth"]
            </button>
        </div>
        @if (_cardDirectionSaved)
        {
            <p class="setting-feedback setting-feedback-success" role="status">
                @Localizer["Settings_CardDirectionSaved"]
            </p>
        }
    </section>

    <section class="settings-card" aria-labelledby="online-lookup-title">
        <h2 id="online-lookup-title">@Localizer["Settings_OnlineDictionary"]</h2>
        <p>@Localizer[AppSettings.HasOnlineLookupConsent
            ? "Settings_OnlineConsentGranted"
            : "Settings_OnlineConsentNotGranted"]</p>
        @if (AppSettings.HasOnlineLookupConsent)
        {
            <button type="button" class="button button-secondary" @onclick="RevokeOnlineConsent">
                @Localizer["Settings_RevokeOnlineConsent"]
            </button>
        }
        @if (_onlineConsentRevoked)
        {
            <p class="setting-feedback setting-feedback-success" role="status">
                @Localizer["Settings_OnlineConsentRevoked"]
            </p>
        }
    </section>

    @if (DiagnosticsEnabled)
    {
        <section class="settings-card" aria-labelledby="lexical-diagnostics-title">
            <h2 id="lexical-diagnostics-title">@Localizer["Diagnostics_LexicalLogTitle"]</h2>
            <p>@Localizer["Diagnostics_LexicalLogDescription"]</p>
            <div class="support-actions">
                <button type="button" class="button button-secondary" disabled="@_isChangingDiagnostics" @onclick="CopyLexicalDiagnosticReportAsync">
                    @Localizer["Diagnostics_CopyDiagnosticReport"]
                </button>
                <button type="button" class="button button-secondary" disabled="@_isChangingDiagnostics" @onclick="ExportLexicalDiagnosticLogAsync">
                    @Localizer["Diagnostics_ExportDiagnosticLog"]
                </button>
                <button type="button" class="button button-secondary" disabled="@_isChangingDiagnostics" @onclick="ClearLexicalDiagnosticLogAsync">
                    @Localizer["Diagnostics_ClearDiagnosticLog"]
                </button>
            </div>
            @if (_diagnosticMessageKey is not null)
            {
                <p class="setting-feedback @(_diagnosticActionFailed ? "setting-feedback-error" : "setting-feedback-success")"
                   role="status"
                   aria-live="polite">
                    @Localizer[_diagnosticMessageKey]
                </p>
            }
        </section>
    }

    <section class="settings-card" aria-labelledby="help-and-support-title">
        <h2 id="help-and-support-title">@Localizer["Settings_HelpAndSupport"]</h2>
        <div class="support-actions">
            <button type="button" class="button button-secondary" @onclick="ShowFeaturePlaceholder">
                @Localizer["Settings_SupportKnownFirst"]
            </button>
            <button type="button" class="button button-secondary" @onclick="ShowFeaturePlaceholder">
                @Localizer["Settings_ReportBug"]
            </button>
        </div>

        @if (_showFeaturePlaceholder)
        {
            <div class="feature-placeholder" role="status">
                <span>@Localizer["Common_FeatureComingSoon"]</span>
                <button type="button" class="button button-secondary" @onclick="CloseFeaturePlaceholder">
                    @Localizer["Common_Close"]
                </button>
            </div>
        }
    </section>

    <section class="settings-card danger-zone" aria-labelledby="reset-data-title">
        <h2 id="reset-data-title">@Localizer["Settings_ResetData"]</h2>
        <p>@Localizer["Settings_ResetDescription"]</p>
        <button type="button"
                class="button button-danger"
                @ref="_resetButton"
                @onclick="ShowResetConfirmation">
            @Localizer["Settings_ResetData"]
        </button>

        @if (_resetSucceeded)
        {
            <p class="inline-message inline-message-success" role="status" aria-live="polite">
                @Localizer["Settings_ResetSuccess"]
            </p>
        }

        @if (_showResetConfirmation)
        {
            <section class="reset-confirmation"
                     role="alertdialog"
                     aria-labelledby="reset-confirmation-title"
                     aria-describedby="reset-confirmation-message"
                     @ref="_resetConfirmation"
                     @onkeydown="HandleResetDialogKeyDown">
                <h2 id="reset-confirmation-title">@Localizer["Settings_ResetConfirmTitle"]</h2>
                <p id="reset-confirmation-message">@Localizer["Settings_ResetConfirmMessage"]</p>
                <div class="button-row">
                    <button type="button"
                            class="button button-secondary"
                            disabled="@_isResetting"
                            @ref="_cancelResetButton"
                            @onclick="CancelReset">
                        @Localizer["Common_Cancel"]
                    </button>
                    <button type="button"
                            class="button button-danger"
                            disabled="@_isResetting"
                            @onclick="ResetDataAsync">
                        @Localizer["Settings_ResetConfirmAction"]
                    </button>
                </div>
                @if (_resetFailed)
                {
                    <p class="inline-message inline-message-error" role="alert">@Localizer["Settings_ResetError"]</p>
                }
            </section>
        }
    </section>
</section>

@code {
    private string _selectedUiLanguage = LanguageSelectionService.EnglishLanguageCode;
    private ThemePreference _selectedTheme = ThemePreference.System;
    private int _selectedPreparationLimit = AppSettingsService.DefaultPreparationLimit;
    private CardDirectionPreference _selectedCardDirection = CardDirectionPreference.Both;
    private string? _languageConfirmation;
    private ThemePreference? _appearanceConfirmation;
    private int? _preparationLimitConfirmation;
    private bool _languageChangeFailed;
    private bool _appearanceChangeFailed;
    private bool _preparationLimitChangeFailed;
    private bool _cardDirectionSaved;
    private bool _onlineConsentRevoked;
    private bool _hasActiveReview;
    private bool _isChangingLanguage;
    private bool _showResetConfirmation;
    private bool _isResetting;
    private bool _resetSucceeded;
    private bool _resetFailed;
    private bool _showFeaturePlaceholder;
    private bool _isChangingDiagnostics;
    private bool _diagnosticActionFailed;
    private string? _diagnosticMessageKey;
    private bool _revealResetConfirmation;
    private bool _returnFocusToResetButton;
    private ElementReference _resetButton;
    private ElementReference _resetConfirmation;
    private ElementReference _cancelResetButton;

    protected override async Task OnInitializedAsync()
    {
        _selectedUiLanguage = LanguageSelection.CurrentUiLanguage;
        _selectedTheme = ThemeService.Preference;
        _selectedPreparationLimit = AppSettings.PreparationLimit;
        _selectedCardDirection = AppSettings.CardDirection;
        _languageConfirmation = SettingsFeedback.ConsumePendingLanguageConfirmation();
        _hasActiveReview = await TextReviewService.GetActiveReviewAsync() is not null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_revealResetConfirmation)
        {
            _revealResetConfirmation = false;
            await JsRuntime.InvokeVoidAsync("knownFirst.revealElement", _resetConfirmation);
            await _cancelResetButton.FocusAsync(preventScroll: true);
        }
        else if (_returnFocusToResetButton)
        {
            _returnFocusToResetButton = false;
            await _resetButton.FocusAsync();
        }
    }

    private bool IsLanguageSelected(string languageCode) =>
        string.Equals(_selectedUiLanguage, languageCode, StringComparison.OrdinalIgnoreCase);

    private bool IsThemeSelected(ThemePreference preference) => _selectedTheme == preference;

    private string GetAppearanceDisplayName(ThemePreference preference) => preference switch
    {
        ThemePreference.Light => Localizer["Settings_AppearanceLight"],
        ThemePreference.Dark => Localizer["Settings_AppearanceDark"],
        _ => Localizer["Settings_AppearanceSystem"]
    };

    private void SelectUiLanguage(string languageCode)
    {
        if (_isChangingLanguage || IsLanguageSelected(languageCode))
        {
            return;
        }

        _isChangingLanguage = true;
        _languageConfirmation = null;
        _languageChangeFailed = false;
        SettingsFeedback.SetPendingLanguageConfirmation(languageCode);

        try
        {
            LanguageSelection.SetUiLanguage(languageCode);
            _selectedUiLanguage = LanguageSelection.CurrentUiLanguage;
        }
        catch (Exception exception)
        {
            SettingsFeedback.ClearPendingLanguageConfirmation();
            Logger.LogError(exception, "The UI language could not be changed.");
            _languageChangeFailed = true;
        }
        finally
        {
            _isChangingLanguage = false;
        }
    }

    private void SelectTheme(ThemePreference preference)
    {
        if (IsThemeSelected(preference))
        {
            return;
        }

        _appearanceConfirmation = null;
        _appearanceChangeFailed = false;

        try
        {
            if (ThemeService.SetPreference(preference))
            {
                _selectedTheme = ThemeService.Preference;
                _appearanceConfirmation = _selectedTheme;
            }
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "The appearance preference could not be changed.");
            _appearanceChangeFailed = true;
        }
    }

    private void SavePreparationLimit()
    {
        _preparationLimitConfirmation = null;
        _preparationLimitChangeFailed = false;

        try
        {
            AppSettings.SetPreparationLimit(_selectedPreparationLimit);
            _selectedPreparationLimit = AppSettings.PreparationLimit;
            _preparationLimitConfirmation = _selectedPreparationLimit;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "The preparation limit could not be saved.");
            _preparationLimitChangeFailed = true;
        }
    }

    private void SelectCardDirection(CardDirectionPreference preference)
    {
        if (_selectedCardDirection == preference)
        {
            return;
        }

        AppSettings.SetCardDirection(preference);
        _selectedCardDirection = AppSettings.CardDirection;
        _cardDirectionSaved = true;
    }

    private void RevokeOnlineConsent()
    {
        AppSettings.RevokeOnlineLookupConsent();
        _onlineConsentRevoked = true;
    }

    private async Task CopyLexicalDiagnosticReportAsync()
    {
        await RunDiagnosticActionAsync(async () =>
        {
            await Microsoft.Maui.ApplicationModel.DataTransfer.Clipboard.Default.SetTextAsync(
                LexicalDiagnosticLog.ReadReport());
            _diagnosticMessageKey = "Diagnostics_DiagnosticReportCopied";
        });
    }

    private async Task ExportLexicalDiagnosticLogAsync()
    {
        await RunDiagnosticActionAsync(async () =>
        {
            await Microsoft.Maui.ApplicationModel.DataTransfer.Share.Default.RequestAsync(
                new Microsoft.Maui.ApplicationModel.DataTransfer.ShareFileRequest
                {
                    Title = Localizer["Diagnostics_ExportDiagnosticLog"],
                    File = new Microsoft.Maui.ApplicationModel.DataTransfer.ShareFile(
                        LexicalDiagnosticLog.ExportPath)
                });
            _diagnosticMessageKey = "Diagnostics_DiagnosticLogExported";
        });
    }

    private Task ClearLexicalDiagnosticLogAsync() => RunDiagnosticActionAsync(() =>
    {
        LexicalDiagnosticLog.Clear();
        _diagnosticMessageKey = "Diagnostics_DiagnosticLogCleared";
        return Task.CompletedTask;
    });

    private async Task RunDiagnosticActionAsync(Func<Task> action)
    {
        _isChangingDiagnostics = true;
        _diagnosticActionFailed = false;
        _diagnosticMessageKey = null;
        try
        {
            await action();
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "The lexical diagnostic log action failed.");
            _diagnosticActionFailed = true;
            _diagnosticMessageKey = "Diagnostics_DiagnosticLogActionError";
        }
        finally
        {
            _isChangingDiagnostics = false;
        }
    }

    private void ShowFeaturePlaceholder() => _showFeaturePlaceholder = true;

    private void CloseFeaturePlaceholder() => _showFeaturePlaceholder = false;

    private static bool DiagnosticsEnabled
    {
        get
        {
#if DEBUG || KNOWNFIRST_DIAGNOSTICS
            return true;
#else
            return false;
#endif
        }
    }

    private void ShowResetConfirmation()
    {
        _resetSucceeded = false;
        _resetFailed = false;
        _showResetConfirmation = true;
        _revealResetConfirmation = true;
    }

    private void CancelReset()
    {
        if (_isResetting)
        {
            return;
        }

        _showResetConfirmation = false;
        _resetFailed = false;
        _returnFocusToResetButton = true;
    }

    private void HandleResetDialogKeyDown(KeyboardEventArgs eventArgs)
    {
        if (eventArgs.Key == "Escape")
        {
            CancelReset();
        }
    }

    private async Task ResetDataAsync()
    {
        _isResetting = true;
        _resetSucceeded = false;
        _resetFailed = false;

        try
        {
            await Database.ResetAsync();
            Microsoft.Maui.Storage.Preferences.Default.Clear();
            ThemeService.ResetPreference();
            AppSettings.Reset();
            _selectedCardDirection = AppSettings.CardDirection;
            LanguageSelection.ResetToDeviceLanguage();
            _showResetConfirmation = false;
            _resetSucceeded = true;
            _returnFocusToResetButton = true;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Local application data could not be reset.");
            _resetFailed = true;
        }
        finally
        {
            _isResetting = false;
        }
    }
}
